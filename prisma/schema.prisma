generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String

  // Onboarding Data
  intent    UserIntent?
  teamSize  TeamSize?
  role      UserRole?
  hasCompletedOnboarding Boolean @default(false)

  // Relations
  workspaces Workspace[] 
  tasks      Task[]      @relation("AssignedTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserIntent {
  PERSONAL
  WORK
  EDUCATION
}

enum TeamSize {
  JUST_ME
  SMALL_TEAM
  MEDIUM_TEAM
  LARGE_TEAM
}

enum UserRole {
  DEVELOPER
  MANAGER
  DESIGNER
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
